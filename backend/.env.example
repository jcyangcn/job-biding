# AI provider: "cursor" (default) or "openai"
AI_PROVIDER=cursor

# Cursor API key — https://cursor.com/dashboard/integrations
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5
# Timeout for each Cursor HTTP request, not the complete agent run.
CURSOR_REQUEST_TIMEOUT=240
# Maximum duration of one agent run, in seconds.
CURSOR_RUN_TIMEOUT=900
# Retries for temporary network/429/5xx failures and invalid generations.
CURSOR_REQUEST_ATTEMPTS=4
CURSOR_GENERATION_ATTEMPTS=3
CURSOR_POLL_INTERVAL=5

# Optional OpenAI fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Server
HOST=0.0.0.0
PORT=8001

# PostgreSQL
DATABASE_URL=postgresql+psycopg2://postgres:123123@localhost:5432/job_bidding

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=48

# Storage folders (optional overrides; relative paths are from project root)
# Default generated PDFs: storage/downloads/generated_resumes
# Default uploads: storage/uploads
# GENERATED_RESUMES_DIR=storage/downloads/generated_resumes
# UPLOADS_DIR=storage/uploads

# Comma-separated extra CORS origins for split UI/API deployments
# CORS_ORIGINS=http://192.168.1.10:3000,https://app.example.com
