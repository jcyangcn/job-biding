# Server
HOST=0.0.0.0
PORT=8001

# PostgreSQL
DATABASE_URL=postgresql+psycopg2://postgres:123123@localhost:5432/job_bidding

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=48

# Generated resume PDF output folder (optional)
# Absolute path, or path relative to the project root.
# Default when unset: <project-root>/generated_resumes
# GENERATED_RESUMES_DIR=C:/github/project/job-bidding/generated_resumes

# Comma-separated extra CORS origins for split UI/API deployments
# CORS_ORIGINS=http://192.168.1.10:3000,https://app.example.com
