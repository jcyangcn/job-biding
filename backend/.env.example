# AI provider: "cursor" (default) or "openai"
AI_PROVIDER=cursor

# Cursor API key — https://cursor.com/dashboard/integrations
CURSOR_API_KEY=cursor_...
CURSOR_MODEL=composer-2.5

# Optional OpenAI fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Server
HOST=0.0.0.0
PORT=8000

# PostgreSQL
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/job_bidding
